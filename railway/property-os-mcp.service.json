{
  "name": "property-os-mcp",
  "purpose": "Always-on MCP server for Property OS resources, dry-run tools, prompts, and future integration workers.",
  "version": "0.2.0",
  "rootDirectory": "mcp/server",
  "dockerfile": "mcp/server/Dockerfile",
  "startCommand": "npm run start:http",
  "healthcheckPath": "/readyz",
  "env": [
    "PROPERTY_OS_MCP_AUTH_MODE",
    "PROPERTY_OS_MCP_AUTH_TOKEN",
    "PROPERTY_OS_MCP_PUBLIC_URL",
    "PROPERTY_OS_MCP_ALLOWED_HOSTS",
    "PROPERTY_OS_MCP_ALLOWED_ORIGINS",
    "PROPERTY_OS_MCP_ALLOWED_TENANTS",
    "PROPERTY_OS_DEFAULT_TENANT_ID",
    "PROPERTY_OS_MCP_OIDC_ISSUER",
    "PROPERTY_OS_MCP_OIDC_AUDIENCE",
    "PROPERTY_OS_MCP_OIDC_JWKS_URL",
    "PROPERTY_OS_MCP_TENANT_CLAIM",
    "PROPERTY_OS_MCP_ROLE_CLAIM",
    "PROPERTY_OS_MCP_ACTOR_ID",
    "PROPERTY_OS_MCP_ACTOR_ROLE",
    "PROPERTY_OS_MCP_STATIC_SCOPES",
    "DATABASE_URL",
    "PROPERTY_OS_AUDIT_MODE",
    "PROPERTY_OS_AI_MODEL",
    "PROPERTY_OS_AI_TIMEOUT_MS",
    "PROPERTY_OS_AI_MAX_OUTPUT_TOKENS",
    "AI_GATEWAY_API_KEY"
  ],
  "firstMilestone": "Deploy authenticated resources, durable missions, governed structured agent drafts, owner review outcomes, dry-run tools, and the internal controlled-transition proof. Keep all external actions blocked.",
  "blockedV1": [
    "publish_listing",
    "send_renter_message",
    "dispatch_vendor",
    "approve_applicant",
    "disclose_access_secret",
    "change_price_or_availability"
  ]
}

# Hosted MCP transport. Use static only for a private single-tenant pilot.
PROPERTY_OS_MCP_AUTH_MODE=static
PROPERTY_OS_MCP_AUTH_TOKEN=
PROPERTY_OS_MCP_PUBLIC_URL=
PROPERTY_OS_MCP_ALLOWED_HOSTS=
PROPERTY_OS_MCP_ALLOWED_ORIGINS=
PROPERTY_OS_DEFAULT_TENANT_ID=sample-org
PROPERTY_OS_MCP_ACTOR_ID=property-os-service
PROPERTY_OS_MCP_ACTOR_ROLE=operator

# Use OIDC for multi-tenant or partner production deployments.
PROPERTY_OS_MCP_OIDC_ISSUER=
PROPERTY_OS_MCP_OIDC_AUDIENCE=
PROPERTY_OS_MCP_OIDC_JWKS_URL=
PROPERTY_OS_MCP_TENANT_CLAIM=tenant_id
PROPERTY_OS_MCP_ROLE_CLAIM=role

# Durable control-plane state. Apply mcp/server/db/001-control-plane.sql first.
DATABASE_URL=
PROPERTY_OS_AUDIT_MODE=dry-run

# Optional production adapters. Configure only after review.
GITHUB_ISSUE_REPO=
OWNER_NOTIFICATION_EMAIL=
RUNTIME_STORE=
EMAIL_PROVIDER=
OBJECT_STORAGE_PROVIDER=
